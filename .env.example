# ── Model brain selector ─────────────────────────────────────────────────
# Pick which LLM powers all three agents. Flip this one var to swap brains
# mid-demo; no code edit. Options: claude | glm | aimlapi | featherless
#   claude      = main brain (the model set in the real .env); validated live
#   glm         = free backup (z.ai); validated live
#   aimlapi     = AI/ML API gateway (optional)
#   featherless = Featherless serverless OSS, Qwen3 family (optional)
MODEL_PROVIDER=claude

# ── glm (z.ai) ───────────────────────────────────────────────────────────
# Get key at https://z.ai/  (the GLM_API_KEY you already use elsewhere).
GLM_API_KEY=
GLM_MODEL=glm-5.2
# International z.ai PAAS endpoint. If you 429 "insufficient balance" on a
# Coding Plan, switch to: https://api.z.ai/api/coding/paas/v4/
GLM_BASE_URL=https://api.z.ai/api/paas/v4/

# ── aimlapi (AI/ML API — partner prize lane) ─────────────────────────────
# Claim the hackathon coupon ($10) at lablab.ai, key at https://aimlapi.com/
# AIMLAPI_MODEL: pick a strong tool-caller, e.g. gpt-4o or a claude-* model.
AIMLAPI_API_KEY=
AIMLAPI_MODEL=gpt-4o
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1

# ── featherless (partner prize lane) ─────────────────────────────────────
# Promo BOA26 ($25, 1 month). Tool-calling = Qwen3 family.
# Pick a model id from https://featherless.ai/models
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=Qwen/Qwen3-235B-A22B
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1

# ── claude (break-glass) ─────────────────────────────────────────────────
# Needs: uv add langchain-anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── Band platform (optional endpoint overrides; default = production) ─────
# BAND_WS_URL=
# BAND_REST_URL=
